# Supabase (required) — for EAS builds, set via `eas secret:create`, not in the repo.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: hosted web app URL for deep links and marketing redirects.
# EXPO_PUBLIC_APP_URL=https://vendorly.app

# Hosted HTTPS bridge for email links (required for reliable reset/confirm on device).
# Upload docs/supabase/auth-redirect.html to Supabase Storage bucket "auth", then set:
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://your-project-ref.supabase.co/storage/v1/object/public/auth/auth-redirect.html

# OAuth redirect: vendorly://auth/callback — add this URL in Supabase Auth → URL Configuration.
# Enable Google + Apple providers in Supabase Dashboard → Authentication → Providers.

# EXPO_PUBLIC_API_URL is optional and only needed for POS/vendor backend features.
# Shopper flows (markets, discover, auth) work without it. Do not set for Supabase-only production builds.
