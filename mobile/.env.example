EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Vendorly NestJS backend (POS, admin AI, proxied market photos). Optional for core shopper flows.
#
# Off LAN / cellular (recommended): public HTTPS URL — same as production web VITE_API_URL.
# EXPO_PUBLIC_API_URL=https://api.vendorly.app
#
# Same Wi‑Fi dev only: your PC's LAN IP (not localhost — the phone cannot reach localhost on your PC).
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4000
#
# Dev off LAN: use a tunnel (ngrok/cloudflared) or deployed API; Metro bundle needs `npx expo start --tunnel`.
# Leave blank to hide POS features; Supabase-only flows still work anywhere.

# Hosted HTTPS bridge for email links (required for reliable reset/confirm on device).
# Upload docs/supabase/auth-redirect.html to Supabase Storage bucket "auth", then set:
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://your-project-ref.supabase.co/storage/v1/object/public/auth/auth-redirect.html

# OAuth redirect: vendorly://auth/callback — add this URL in Supabase Auth → URL Configuration.
# Enable Google + Apple providers in Supabase Dashboard → Authentication → Providers.
