# ---------------------------------------------------------------------------
# Vendorly backend environment
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# Postgres (same Supabase database the mobile app uses).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rooted

# Redis for BullMQ (sync + aggregation job queues).
# Upstash (easiest): Connect → TCP tab → copy the full REDIS_URL (rediss://...).
REDIS_URL=
# Local dev: leave POS_QUEUES_ENABLED=false (default when NODE_ENV≠production).
# POS sync/aggregation still work inline — no Redis workers needed.
# Set true only when you have Redis headroom (production or local Redis).
POS_QUEUES_ENABLED=false
# Or discrete vars for local Redis:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# 32-byte key (base64) used for AES-256-GCM credential encryption at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
POS_CREDENTIAL_KEY=

# Public base URL of this backend (production default).
PUBLIC_BASE_URL=https://api.vendorly.app

# Web app origin for CORS (Vite dev / production site). Comma-separate for multiple.
# Production / off-LAN: set to your Vercel or custom domain (required for browser API calls).
WEB_APP_URL=http://localhost:5173
# CORS_ORIGINS=https://vendorly.app,https://www.vendorly.app,https://your-project.vercel.app
# In dev, private LAN IPs (10.x, 192.168.x) are allowed automatically.

# HTTPS URL for POS provider OAuth redirects + webhooks. Required for Square (HTTPS only).
# Local dev: run `ngrok http 4000` and paste the https:// URL here. Mobile can still use
# a LAN IP via EXPO_PUBLIC_API_URL. See docs/SQUARE_SETUP.md.
POS_PROVIDER_BASE_URL=

# Deep link the OAuth callback bounces back to after connecting.
# Must match the mobile app scheme (app.json "scheme": "vendorly"). In Expo Go dev,
# set this to the printed exp:// URL + /pos/connected instead.
APP_DEEP_LINK=vendorly://pos/connected

# Supabase auth verification (vendor/admin auth guard).
# New projects: set SUPABASE_URL — tokens are ES256, verified via JWKS.
SUPABASE_URL=https://your-project.supabase.co
# Legacy HS256 projects only:
SUPABASE_JWT_SECRET=

# --- Square ---
# Sandbox app: developer.squareup.com → OAuth redirect (HTTPS only) =
#   ${POS_PROVIDER_BASE_URL}/pos/oauth/square/callback
# See docs/SQUARE_SETUP.md for the full checklist.
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
# Application access token (Credentials tab — NOT the OAuth secret). Required for webhooks.
SQUARE_ACCESS_TOKEN=
# Fallback global webhook signing key. Auto-registered connections store their own
# per-subscription signature_key on the connection, so this is only a fallback.
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Optional: comma-separated override of subscribed webhook event types. These must
# also be enabled on the Square application's Webhooks settings.
SQUARE_WEBHOOK_EVENT_TYPES=

# --- Toast ---
# TODO: verify with provider docs (Toast partner onboarding / credentials model)
TOAST_ENVIRONMENT=sandbox
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_WEBHOOK_SECRET=

# --- Clover ---
CLOVER_ENVIRONMENT=sandbox
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_WEBHOOK_SECRET=

# --- Market discovery agent (daily sync every 24h at 04:00 server time) ---
# Apply docs/supabase/phase13_market_agent.sql + phase14 + phase15 + phase21 first.
MARKETS_AGENT_ENABLED=false
MARKETS_AGENT_CRON_ENABLED=true
# deep = tiled Overpass + Nominatim metros per state (~60–90 min). fast = Overpass only.
MARKETS_DISCOVERY_MODE=deep
MARKETS_DISCOVERY_ENABLED=true
MARKETS_REFRESH_BATCH=500
# Bulk catalog enrichment (all imported markets): batch size per run / npm run markets:enrich
MARKETS_ENRICH_BATCH=50
MARKETS_ENRICH_DELAY_MS=300
# Optional Nominatim lookup before AI for named markets (slow; off by default for bulk).
MARKETS_CATALOG_NOMINATIM=false
# Optional: enrich market type, hours, parking, extra info with OpenAI (server-side only).
# Fills what_to_look_for, market_highlights, vendor categories, and shopper tips for USDA markets.
OPENAI_API_KEY=
MARKETS_AI_ENRICH=true
MARKETS_AI_ENRICH_ALWAYS=false
MARKETS_AI_MODEL=gpt-4o-mini

# --- Google Places photos (optional fallback — costs ~$0.04/market) ---
# Cheapest: leave GOOGLE_PLACES_API_KEY empty and use npm run markets:images (free).
# With a key: free OSM/Commons/website runs first; Google only when those find nothing.
GOOGLE_PLACES_API_KEY=
MARKETS_GOOGLE_PLACES_ENABLED=true
# Set false to stay on free sources only (Commons geosearch + website og:image + vision).
MARKETS_GOOGLE_PLACES_FALLBACK=false

# --- Market image vision verification (OpenAI — pennies per image) ---
# Commons geosearch + website og:image require vision approval before saving.
MARKETS_IMAGE_VISION_ENABLED=true
MARKETS_IMAGE_VISION_MIN_CONFIDENCE=0.85
MARKETS_IMAGE_VISION_MODEL=gpt-4o-mini
# PUBLIC_BASE_URL must be reachable from phones when using Google proxy URLs.

# --- AI admin agent (vendor application triage — human still approves/rejects) ---
# Apply docs/supabase/phase17_admin_agent.sql first.
ADMIN_VENDOR_AGENT_ENABLED=false
ADMIN_VENDOR_AGENT_CRON_ENABLED=true
# Pending vendors reviewed per run (nightly cron + npm run admin:agent).
ADMIN_VENDOR_REVIEW_BATCH=20
ADMIN_VENDOR_REVIEW_DELAY_MS=400
ADMIN_VENDOR_AI_MODEL=gpt-4o-mini
# Past approve/reject decisions injected into each AI review prompt.
ADMIN_VENDOR_FEEDBACK_EXAMPLES=15

# --- AI post/video moderation ---
# Apply docs/supabase/phase19_post_moderation.sql first.
ADMIN_POST_AGENT_ENABLED=false
ADMIN_POST_AGENT_CRON_ENABLED=true
ADMIN_POST_MODERATION_BATCH=25
ADMIN_POST_MODERATION_DELAY_MS=500
ADMIN_POST_AI_MODEL=gpt-4o-mini
ADMIN_POST_FEEDBACK_EXAMPLES=15

# --- Stripe (Phase 32 — Connect + Checkout) ---
# Apply docs/supabase/phase32_stripe_messaging.sql in Supabase first.
# Test keys: dashboard.stripe.com → Developers → API keys.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from Stripe CLI (`stripe listen`) or Dashboard endpoint.
STRIPE_WEBHOOK_SECRET=
# Optional override of platform fee in basis points (default 500 = 5%).
# STRIPE_PLATFORM_FEE_BPS=500
