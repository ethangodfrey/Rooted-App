VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public site URL for email confirm / password reset links.
# On LAN/phone testing, leave unset — the app uses window.location.origin automatically.
# VITE_APP_URL=http://localhost:5173

# Support URL for App Store Connect and in-app links (mailto: or help page).
# VITE_SUPPORT_URL=mailto:support@rooted.app

# Backend API (optional in dev — auto-detected from your current host on port 4000).
# Set explicitly for production, e.g. VITE_API_URL=https://api.yourdomain.com
# VITE_API_URL=http://localhost:4000
