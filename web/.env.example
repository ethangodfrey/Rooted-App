# Supabase (same project as mobile/ — copy EXPO_PUBLIC_* values here)
# Market/event listings are loaded from Supabase (events table + search_all RPC), not Google Places.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public site URL for email confirm / password reset / OAuth links.
# Dev: leave unset — the app uses window.location.origin automatically.
# VITE_APP_URL=http://localhost:5173

# Backend API (optional). POS, admin AI, and proxied market photos only.
# Omit in production to ship Supabase-only on Vercel — see docs/DEPLOY.md § "Ship without backend".
# Dev on same Wi‑Fi: leave unset — the app uses your current host on port 4000.
# Dev/production off LAN: set to a public HTTPS URL (deployed API or ngrok/cloudflared tunnel).
# VITE_API_URL=http://localhost:4000

# --- Production / off-LAN (set in Vercel/host env — do not commit real values) ---
# VITE_APP_URL=https://vendorly.app
# VITE_API_URL=https://api.vendorly.app   # optional until backend is deployed
# See docs/OFF_LAN_ACCESS.md for cellular, tunnel, and CORS setup.

# Google & Apple sign-in (required for OAuth buttons):
# 1. Supabase → Authentication → Providers → enable Google/Apple + paste client credentials
# 2. Supabase → Authentication → URL Configuration → Redirect URLs → http://localhost:5173/auth/callback
# 3. Google Cloud → OAuth client → Authorized redirect URI → https://YOUR-PROJECT.supabase.co/auth/v1/callback
# 4. Production: add https://vendorly.app/auth/callback and https://vendorly.app/auth/reset-password
